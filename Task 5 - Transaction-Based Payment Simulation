import java.sql.*;

public class PaymentTransactionSimulation {

    public static void main(String[] args) {
        String url = "jdbc:h2:mem:paymentDB;DB_CLOSE_DELAY=-1";
        String user = "sa";
        String password = "";

        try (Connection conn = DriverManager.getConnection(url, user, password)) {
            conn.setAutoCommit(false); // Important: Manual transaction control

            Statement stmt = conn.createStatement();

            // Create tables
            stmt.execute("CREATE TABLE IF NOT EXISTS user_account (" +
                    "id INT PRIMARY KEY, " +
                    "balance DECIMAL(10,2) NOT NULL)");

            stmt.execute("CREATE TABLE IF NOT EXISTS merchant_account (" +
                    "id INT PRIMARY KEY, " +
                    "balance DECIMAL(10,2) NOT NULL)");

            // Initialize balances
            stmt.execute("INSERT OR REPLACE INTO user_account (id, balance) VALUES (1, 1000.00)");
            stmt.execute("INSERT OR REPLACE INTO merchant_account (id, balance) VALUES (1, 0.00)");

            System.out.println("=== TRANSACTION-BASED PAYMENT SIMULATION ===");
            showBalances(conn, "INITIAL BALANCES");

            // Success Case
            simulatePayment(conn, 250.00, true);

            // Reset for failure demo
            resetBalances(conn);
            System.out.println("\n=== RESET FOR FAILURE DEMO ===");
            showBalances(conn, "BALANCES RESET");

            // Failure Case
            simulatePayment(conn, 150.00, false);

            System.out.println("\n=== Simulation Complete ===");

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }

    private static void showBalances(Connection conn, String label) throws SQLException {
        try (Statement stmt = conn.createStatement()) {
            ResultSet rsUser = stmt.executeQuery("SELECT balance FROM user_account WHERE id = 1");
            double userBalance = rsUser.next() ? rsUser.getDouble("balance") : 0.0;

            ResultSet rsMerchant = stmt.executeQuery("SELECT balance FROM merchant_account WHERE id = 1");
            double merchantBalance = rsMerchant.next() ? rsMerchant.getDouble("balance") : 0.0;

            System.out.printf("%s - User Balance: $%.2f | Merchant Balance: $%.2f%n",
                    label, userBalance, merchantBalance);
        }
    }

    private static void simulatePayment(Connection conn, double amount, boolean shouldSucceed) {
        System.out.printf("\n--- Processing Payment of $%.2f ---%n", amount);
        System.out.println("Expected outcome: " + (shouldSucceed ? "SUCCESS (COMMIT)" : "FAILURE (ROLLBACK)"));

        try {
            // Start transaction
            conn.setAutoCommit(false);

            try (PreparedStatement deductStmt = conn.prepareStatement(
                    "UPDATE user_account SET balance = balance - ? WHERE id = 1");
                 PreparedStatement addStmt = conn.prepareStatement(
                         "UPDATE merchant_account SET balance = balance + ? WHERE id = 1")) {

                // Deduct from user
                deductStmt.setDouble(1, amount);
                deductStmt.executeUpdate();

                // Add to merchant
                addStmt.setDouble(1, amount);
                addStmt.executeUpdate();

                if (!shouldSucceed) {
                    throw new SQLException("Simulated failure: Payment gateway error / Insufficient funds");
                }

                // Commit on success
                conn.commit();
                System.out.println("✅ TRANSACTION SUCCESSFUL - COMMIT executed");
            }

        } catch (SQLException e) {
            try {
                conn.rollback();
                System.out.println("❌ TRANSACTION FAILED - ROLLBACK executed: " + e.getMessage());
            } catch (SQLException rollbackEx) {
                System.out.println("Error during rollback: " + rollbackEx.getMessage());
            }
        }
    }

    private static void resetBalances(Connection conn) throws SQLException {
        try (Statement stmt = conn.createStatement()) {
            stmt.execute("UPDATE user_account SET balance = 1000.00 WHERE id = 1");
            stmt.execute("UPDATE merchant_account SET balance = 0.00 WHERE id = 1");
            conn.commit();
        }
    }
}
